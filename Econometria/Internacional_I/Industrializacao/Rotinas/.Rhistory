dados_1999 <- read_csv("ex_1999.csv")
head(dados_1999)
str(dados_1999)
str(dados_1999)
View(dados_1999)
dados_1999_limpo <- dados_1999 %>%
filter(
flowCode == "X",            # Exportações
reporterISO == "BRA",        # Brasil
classificationCode == "B4",  # BEC Rev.4 (indústria)
partnerISO != "W00"          # remove agregado "World"
) %>%
transmute(
ano   = refYear,
pais  = partnerDesc,
iso3  = partnerISO,
valor = fobvalue
) %>%
group_by(ano, iso3, pais) %>%
summarise(
valor = sum(valor, na.rm = TRUE),
.groups = "drop"
)
View(dados_1999_limpo)
total_1999 <- sum(dados_1999_limpo$valor, na.rm = TRUE)
total_1999 <- sum(dados_1999_limpo$valor, na.rm = TRUE)
total_1999
mundo <- ne_countries(scale = "medium", returnclass = "sf")
mapa_1999 <- mundo %>%
left_join(
dados_1999_limpo,
by = c("iso_a3" = "iso3")
)
View(mapa_1999)
# mapa mundi
mundo <- ne_countries(scale = "medium", returnclass = "sf")
# join com os dados de exportação
mapa_1999 <- mundo %>%
left_join(
dados_1999_limpo,
by = c("iso_a3" = "iso3")
)
# total exportado (para o subtítulo)
total_1999 <- sum(dados_1999_limpo$valor, na.rm = TRUE)
# plot
ggplot(mapa_1999) +
geom_sf(aes(fill = valor), color = "gray60", size = 0.1) +
scale_fill_viridis_c(
option = "C",
trans = "log10",
na.value = "gray90",
labels = label_number(scale = 1e-9, suffix = " bi US$")
) +
labs(
title = "Exportações Industriais Brasileiras por Destino – 1999",
subtitle = paste0(
"Total exportado: ",
label_number(scale = 1e-9, suffix = " bilhões US$")(total_1999)
),
fill = "US$ FOB"
) +
theme_minimal()
dados_1999_limpo %>%
arrange(desc(valor)) %>%
head(10)
View(mundo)
