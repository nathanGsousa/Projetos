)
# total exportado (para o subtítulo)
total_1999 <- sum(dados_1999_limpo$valor, na.rm = TRUE)
# plot
ggplot(mapa_1999) +
geom_sf(aes(fill = valor), color = "gray60", size = 0.1) +
scale_fill_viridis_c(
option = "C",
trans = "log1p",                # <<< mudança chave
na.value = "gray90",
labels = label_number(
scale = 1e-9,
suffix = " bi US$",
accuracy = 0.01
)
) +
labs(
title = "Exportações Industriais Brasileiras por Destino – 1999",
subtitle = paste0(
"Total exportado: ",
label_number(
scale = 1e-9,
suffix = " bilhões US$",
accuracy = 0.01
)(total_1999)
),
fill = "US$ FOB"
) +
theme_minimal() +
theme(
legend.position = "right",
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(size = 10)
)
