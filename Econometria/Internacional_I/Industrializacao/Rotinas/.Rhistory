library(tidyverse)
library(readxl)
library(sf)
library(rnaturalearth)
library(rnaturalearthdata)
library(rnaturalearth)
library(scales)
dados_1999 <- read_xlsx("EXPORTACAO_1999.xlsx")
head(dados_1999)
str(dados_1999)
dados_1999_limpo <- dados_1999 %>%
select(
pais = Países,
valor = `1999 - Valor US$ FOB`
)
total_1999 <- sum(dados_1999_limpo$valor, na.rm = TRUE)
total_1999
mundo <- ne_countries(scale = "medium", returnclass = "sf")
install.packages('rnaturalearthdata')
library(rnaturalearthdata)
mundo <- ne_countries(scale = "medium", returnclass = "sf")
dados_1999_limpo <- dados_1999_limpo %>%
mutate(
pais = case_when(
pais == "Estados Unidos" ~ "United States of America",
pais == "Países Baixos (Holanda)" ~ "Netherlands",
pais == "Reino Unido" ~ "United Kingdom",
TRUE ~ pais
)
)
mapa_1999 <- mundo %>%
left_join(
dados_1999_limpo,
by = c("name_long" = "pais")
)
```{r mapa-1999, fig.width=10, fig.height=6}
ggplot(mapa_1999) +
geom_sf(aes(fill = valor), color = "gray50", size = 0.1) +
scale_fill_viridis_c(
option = "C",
trans = "log",
na.value = "gray90",
labels = label_number(scale = 1e-9, suffix = " bi US$")
) +
labs(
title = "Exportações Industriais Brasileiras por Destino – 1999",
subtitle = paste0(
"Total exportado: ",
label_number(scale = 1e-9, suffix = " bilhões US$")(total_1999)
),
fill = "Exportações"
) +
theme_minimal()
install.packages('countrycode')
library(countrycode)
```{r preparar-dados-1999}
dados_1999_limpo <- dados_1999 %>%
transmute(
pais_nome = Países,
iso3 = countrycode(
Países,
origin = "country.name.pt",
destination = "iso3c"
),
valor = `1999 - Valor US$ FOB`
)
