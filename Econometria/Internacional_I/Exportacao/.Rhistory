glimpse(cms)
cms_periodos <- cms %>%
pivot_wider(
names_from = periodo,
values_from = valor_fob,
values_fill = 0
)
cms_periodos_ne <- cms_ne %>%
pivot_wider(
names_from = periodo,
values_from = valor_fob,
values_fill = 0
)
cms_periodos <- cms_periodos %>%
mutate(
delta_12 = P2 - P1,
delta_23 = P3 - P2
)
cms_periodos_ne <- cms_periodos_ne %>%
mutate(
delta_12 = P2 - P1,
delta_23 = P3 - P2
)
